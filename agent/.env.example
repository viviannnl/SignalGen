# Safe template only. Copy this to .env and fill real values locally.
# Never commit agent/.env.

# Required for local ADK TypeScript Gemini calls:
# https://adk.dev/get-started/typescript/#set-your-api-key
GEMINI_API_KEY=replace_me

# Required when tools need to read/write SignalGen memory directly:
MONGODB_URI=replace_me

# Optional deployment/runtime values:
GOOGLE_CLOUD_PROJECT=signalgen-496700
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_TICK_SECRET=replace_me
