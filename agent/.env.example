# Safe template only. Copy this to .env and fill real values locally.
# Never commit agent/.env or any real secret values.

# Required for local ADK TypeScript Gemini calls:
# https://adk.dev/get-started/typescript/#set-your-api-key
GEMINI_API_KEY=

# Required when the ADK agent reads/writes SignalGen memory directly.
MONGODB_URI=

# Google Cloud project/location for future Agent Engine / Vertex AI work.
GOOGLE_CLOUD_PROJECT=signalgen-496700
GOOGLE_CLOUD_LOCATION=us-central1

# Optional shared secret for future scheduled/manual agent tick endpoints.
AGENT_TICK_SECRET=
