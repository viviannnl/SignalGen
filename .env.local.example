# Safe template only. Copy this to .env.local and fill real values locally.
# Never commit .env.local or any real secret values.

# MongoDB Atlas connection string for SignalGen memory storage.
MONGODB_URI=

# Google Cloud project created for SignalGen.
GOOGLE_CLOUD_PROJECT=signalgen-496700

# Gemini API key for local development if the Next.js app calls Gemini directly.
GEMINI_API_KEY=

# GitHub access token for approved PR automation.
# Use a fine-grained token if possible; keep permissions scoped to the target repo.
GITHUB_TOKEN=

# Owner (GitHub username or org) and name of the product repo SignalGen is allowed to modify.
TARGET_REPO_OWNER=
TARGET_REPO_NAME=

# Optional: Vercel API token for deployment/preview metadata lookup.
VERCEL_TOKEN=

# Random secret to protect /api/agent/tick from unauthenticated callers.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TICK_SECRET=
